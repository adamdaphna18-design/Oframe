# .env – AI Agent Economy Environment Variables

# --- Core ---
AGENT_ID=my_agent_001
DEBUG=true
LOG_LEVEL=DEBUG

# --- Local Services ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
REPUTATION_SERVICE_URL=http://localhost:5010
PRICING_SERVICE_URL=http://localhost:5011
MARKETPLACE_URL=http://localhost:5012
ROUTER_SERVICE_URL=http://localhost:5013

# --- Revenue Stream Servers ---
SPECTRUM_SERVER_URL=http://localhost:5001
ROBOT_SERVER_URL=http://localhost:5002
INFERENCE_SERVER_URL=http://localhost:5003
TRADING_SERVER_URL=http://localhost:5004
THREAT_SERVER_URL=http://localhost:5005

# --- Payment (x402) – optional, for real payments ---
