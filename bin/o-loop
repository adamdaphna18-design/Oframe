#!/usr/bin/env python3
import sys
import time
import logging
from pathlib import Path
from dotenv import load_dotenv

load_dotenv()

# Setup logging
logging.basicConfig(level=logging.INFO, format="%(message)s")
logger = logging.getLogger(__name__)

sys.path.insert(0, str(Path(__file__).parent.parent))
from oframe.core import ask_ollama, profit_score
from oframe.plugin_manager import PluginManager

# Initialize PluginManager
pm = PluginManager([Path.home() / ".oframe" / "plugins", Path(__file__).parent.parent / "oframe" / "plugins"])
pm.discover_and_load()

question = "What's the fastest way to make $100 today?"
next_q = "How do I start?"

for i in range(5):
    # Try to get skill answer
    skill_answer = pm.get_matched_answer(question)

    if skill_answer:
        ans = skill_answer
        logger.info("⚡ Hermes shortcut – used learned skill")
    else:
        ans = ask_ollama(question)

    score = profit_score(ans)
    print(f"Loop {i}: {ans[:100]}... (score {score})")

    pm.on_iteration_all(i, question, ans, score, next_q)

    # Simulate a golden idea if score is high enough
    if score >= 3:
        idea = {
            "question": question,
            "answer": ans,
            "score": score,
            "next_question": next_q,
            "plan_path": "templates/mvp_plan.md.j2"
        }
        pm.on_golden_idea_all(idea)

    time.sleep(1)

pm.on_shutdown_all()
