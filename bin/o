#!/usr/bin/env python3
import sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).parent.parent))
from oframe.core import ask_ollama

if len(sys.argv) < 2:
    print("Usage: o ask <question>")
    sys.exit(1)
if sys.argv[1] == "ask":
    answer = ask_ollama(" ".join(sys.argv[2:]))
    print(answer)
else:
    print("Unknown command")
